{
  "name": "fleetos",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter @fleetos/api db:migrate",
    "db:seed": "pnpm --filter @fleetos/api db:seed"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  }
}
